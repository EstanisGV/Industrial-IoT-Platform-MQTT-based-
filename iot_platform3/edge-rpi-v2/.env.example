APP_ENV=development

# Protocol: mock, s7, opcua
PLC_PROTOCOL=mock

# S7
PLC_IP=192.168.1.60
PLC_RACK=0
PLC_SLOT=1
PLC_DB_NUMBER=100

# OPC UA
OPCUA_URL=opc.tcp://192.168.1.50:4840
OPCUA_USERNAME=
OPCUA_PASSWORD=

# MQTT Broker
MQTT_HOST=192.168.1.100
MQTT_PORT=1883
MQTT_USERNAME=index_ms40_01
MQTT_PASSWORD=CHANGE_ME
MQTT_CLIENT_ID=edge-index_ms40_01
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_CONNECT_TIMEOUT=10
MQTT_RECONNECT_INITIAL_DELAY=2
MQTT_RECONNECT_MAX_DELAY=60

# TLS / MQTTS
MQTT_TLS_ENABLED=false
MQTT_TLS_CA_CERT=/app/certs/ca.crt
MQTT_TLS_CLIENT_CERT=/app/certs/client.crt
MQTT_TLS_CLIENT_KEY=/app/certs/client.key
MQTT_TLS_INSECURE=false

# Polling / Heartbeat
POLL_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Optional metadata
SERVICE_VERSION=0.2.0
