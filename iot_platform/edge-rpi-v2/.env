APP_ENV=development

# Protocol: mock, s7, opcua
PLC_PROTOCOL=mock

# S7
PLC_IP=
PLC_RACK=0
PLC_SLOT=1
PLC_DB_NUMBER=100

# OPC UA
OPCUA_URL=
OPCUA_USERNAME=
OPCUA_PASSWORD=

# MQTT Broker
#MQTT_HOST=
#MQTT_PORT=8883
#MQTT_USERNAME=edge_index_ms40_01
#MQTT_PASSWORD=CHANGE_ME
#MQTT_CLIENT_ID=rpi-index-ms40-01
#MQTT_QOS=1
#MQTT_RETAIN=false
#MQTT_CONNECT_TIMEOUT=10
#MQTT_RECONNECT_INITIAL_DELAY=2
#MQTT_RECONNECT_MAX_DELAY=60

MQTT_HOST=host.docker.internal
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=rpi-index-ms40-01


# TLS / MQTTS
#MQTT_TLS_ENABLED=true
#MQTT_TLS_CA_CERT=/app/certs/ca.crt
#MQTT_TLS_CLIENT_CERT=/app/certs/client.crt
#MQTT_TLS_CLIENT_KEY=/app/certs/client.key
#MQTT_TLS_INSECURE=false

MQTT_TLS_ENABLED=false
MQTT_TLS_CA_CERT=
MQTT_TLS_CLIENT_CERT=
MQTT_TLS_CLIENT_KEY=
MQTT_TLS_INSECURE=false

# Polling / Heartbeat
POLL_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL_SECONDS=10

# Logging
LOG_LEVEL=INFO

# Optional metadata
SERVICE_VERSION=0.2.0
